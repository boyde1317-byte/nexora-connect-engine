modules = ["nodejs-24", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_NAME = "Nexora Connect Engine"
APP_VERSION = "1.0.0"
BASE_PATH = "/api"
CORS_ORIGINS = "http://localhost:3000,http://localhost:5173"
JWT_ACCESS_EXPIRES_IN = "15m"
JWT_ACCESS_SECRET = "nexora-access-jwt-secret-dev-key-change-in-prod-minimum-32chars-secure"
JWT_REFRESH_EXPIRES_IN = "7d"
JWT_REFRESH_SECRET = "nexora-refresh-jwt-secret-dev-key-change-in-prod-minimum-32chars-secure"
LOG_LEVEL = "info"
LOG_PRETTY = "true"
MAX_SESSIONS_PER_USER = "10"
RATE_LIMIT_MAX = "100"
RATE_LIMIT_WINDOW = "60000"
REDIS_URL = "redis://localhost:6379"
SESSION_MAX_RETRIES = "5"
SESSION_RECONNECT_DELAY = "5000"
