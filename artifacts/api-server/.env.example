# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
APP_NAME="Nexora Connect Engine"
APP_VERSION=1.0.0
BASE_PATH=/api

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/nexora_connect

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS=false

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ──────────────────────────────────────────────────────────────
ENCRYPTION_KEY=32-char-hex-string-for-aes-256-encryption

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# ─── Session ─────────────────────────────────────────────────────────────────
MAX_SESSIONS_PER_USER=10
SESSION_RECONNECT_DELAY=5000
SESSION_MAX_RETRIES=5

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=true

# ─── Cors ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
