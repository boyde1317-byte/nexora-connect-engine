// Nexora Connect Engine — Prisma Schema
// Production-grade WhatsApp session management platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
  VIEWER
}

enum SessionStatus {
  CONNECTING
  QR_PENDING
  PAIRING_PENDING
  CONNECTED
  DISCONNECTED
  BANNED
  EXPIRED
  ERROR
}

enum SessionConnectionType {
  QR_CODE
  PAIRING_CODE
}

enum QueueJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
}

// ─── Users ──────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sessions      Session[]
  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]

  @@index([email])
  @@map("users")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  keyHash     String   @unique @map("key_hash")
  keyPrefix   String   @map("key_prefix")
  userId      String   @map("user_id")
  lastUsedAt  DateTime? @map("last_used_at")
  expiresAt   DateTime? @map("expires_at")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([keyHash])
  @@index([userId])
  @@map("api_keys")
}

// ─── WhatsApp Sessions ──────────────────────────────────────────────────────

model Session {
  id             String               @id @default(uuid())
  name           String
  description    String?
  status         SessionStatus        @default(DISCONNECTED)
  connectionType SessionConnectionType @default(QR_CODE)
  phoneNumber    String?              @map("phone_number")
  pushName       String?              @map("push_name")
  userId         String               @map("user_id")
  qrCode         String?              @map("qr_code")
  pairingCode    String?              @map("pairing_code")
  retryCount     Int                  @default(0) @map("retry_count")
  maxRetries     Int                  @default(5) @map("max_retries")
  lastConnectedAt DateTime?           @map("last_connected_at")
  lastErrorAt    DateTime?            @map("last_error_at")
  lastError      String?              @map("last_error")
  webhookUrl     String?              @map("webhook_url")
  metadata       Json?
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  authState SessionAuthState?
  events    SessionEvent[]

  @@index([userId])
  @@index([status])
  @@map("sessions")
}

// ─── Baileys Auth State ──────────────────────────────────────────────────────

model SessionAuthState {
  id        String   @id @default(uuid())
  sessionId String   @unique @map("session_id")
  creds     Json
  keys      Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("session_auth_states")
}

// ─── Session Events ──────────────────────────────────────────────────────────

model SessionEvent {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  type      String
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([type])
  @@index([createdAt])
  @@map("session_events")
}

// ─── Queue Jobs ──────────────────────────────────────────────────────────────

model QueueJob {
  id          String         @id @default(uuid())
  jobId       String         @unique @map("job_id")
  queue       String
  name        String
  payload     Json
  status      QueueJobStatus @default(PENDING)
  attempts    Int            @default(0)
  failedReason String?       @map("failed_reason")
  processedAt DateTime?      @map("processed_at")
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([queue])
  @@index([status])
  @@map("queue_jobs")
}
